	chapter_group.03497C590C825466.title: "Create"
	quest.77AF2E0E903E3F22.quest_desc: ["Ціль данних квестів навчити вас працювати з Create. Пояснити за основні механіки мода і навчити робити базові ферми і автоматизації. Всю необхідну базу ви можете знайти в вкладці &e&lБазовий&r&r &e&lCreate&r&r та вкладках аддонів до нього. Якщо під якиїсь аддон до Create не було виділино окрему вкладку квестів значить він є косметиччним або не так сильно впливає на геймплей."]
	quest.77AF2E0E903E3F22.title: "Create"
	task.7D33CA1B170F75C5.title: "Про квести"
